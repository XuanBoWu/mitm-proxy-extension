{
  "name": "secmp",
  "displayName": "SecMP",
  "icon": "media/icon.png",
  "description": "%secmp.description%",
  "version": "0.1.9",
  "publisher": "xbowu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/XuanBoWu/mitm-proxy-extension.git"
  },
  "bugs": {
    "url": "https://github.com/XuanBoWu/mitm-proxy-extension/issues"
  },
  "homepage": "https://github.com/XuanBoWu/mitm-proxy-extension#readme",
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "android",
    "adb",
    "mitm",
    "proxy",
    "security",
    "traffic-capture"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "scripts": {
    "runtime:macos": "bash scripts/build-macos-runtime.sh",
    "runtime:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-runtime.ps1",
    "runtime:windows:test-install": "node scripts/test-extension-runtime-install.js",
    "l10n:check": "node scripts/check-l10n.js"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:secmp.sidebar"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "SecMP",
      "properties": {
        "secmp.runtimePath": {
          "type": "string",
          "default": "",
          "description": "%secmp.config.runtimePath%"
        },
        "secmp.runtimeArchivePath": {
          "type": "string",
          "default": "",
          "description": "%secmp.config.runtimeArchivePath%"
        },
        "secmp.runtimeUrl": {
          "type": "string",
          "default": "",
          "description": "%secmp.config.runtimeUrl%"
        },
        "secmp.runtimeSha256": {
          "type": "string",
          "default": "",
          "description": "%secmp.config.runtimeSha256%"
        },
        "secmp.runtimeVersion": {
          "type": "string",
          "default": "0.1.2",
          "description": "%secmp.config.runtimeVersion%"
        },
        "secmp.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "zh-CN",
            "en-US"
          ],
          "enumDescriptions": [
            "%secmp.config.language.auto%",
            "%secmp.config.language.zhCN%",
            "%secmp.config.language.enUS%"
          ],
          "description": "%secmp.config.language%"
        },
        "secmp.windowsRuntimePath": {
          "type": "string",
          "default": "",
          "description": "%secmp.config.windowsRuntimePath%"
        },
        "secmp.windowsRuntimeArchivePath": {
          "type": "string",
          "default": "",
          "description": "%secmp.config.windowsRuntimeArchivePath%"
        },
        "secmp.windowsRuntimeUrl": {
          "type": "string",
          "default": "",
          "description": "%secmp.config.windowsRuntimeUrl%"
        },
        "secmp.windowsRuntimeSha256": {
          "type": "string",
          "default": "",
          "description": "%secmp.config.windowsRuntimeSha256%"
        },
        "secmp.windowsRuntimeVersion": {
          "type": "string",
          "default": "0.1.2",
          "description": "%secmp.config.windowsRuntimeVersion%"
        },
        "secmp.updateCheckEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%secmp.config.updateCheckEnabled%"
        },
        "secmp.updateCheckIntervalHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "description": "%secmp.config.updateCheckIntervalHours%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "secmp",
          "title": "%secmp.viewsContainer.title%",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "secmp": [
        {
          "id": "secmp.sidebar",
          "name": "%secmp.view.sidebar.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "secmp.startProxy",
        "title": "%secmp.command.startProxy%"
      },
      {
        "command": "secmp.stopProxy",
        "title": "%secmp.command.stopProxy%"
      },
      {
        "command": "secmp.pushCert",
        "title": "%secmp.command.pushCert%"
      },
      {
        "command": "secmp.setupProxy",
        "title": "%secmp.command.setupProxy%"
      },
      {
        "command": "secmp.clearProxy",
        "title": "%secmp.command.clearProxy%"
      },
      {
        "command": "secmp.cleanRuntimeCache",
        "title": "%secmp.command.cleanRuntimeCache%"
      },
      {
        "command": "secmp.checkForUpdates",
        "title": "%secmp.command.checkForUpdates%"
      },
      {
        "command": "secmp.exportHar",
        "title": "%secmp.command.exportHar%"
      },
      {
        "command": "secmp.exportJson",
        "title": "%secmp.command.exportJson%"
      },
      {
        "command": "secmp.showPanel",
        "title": "%secmp.command.showPanel%"
      }
    ]
  }
}
