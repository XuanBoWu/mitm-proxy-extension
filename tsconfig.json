{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": [
      "ES2020"
    ],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "extension.js",
    "secmp_session.js",
    "mcp_bridge.js",
    "mcp/**/*.js",
    "scripts/**/*.js",
    "types/**/*.d.ts"
  ]
}
